# Приложение
APP_ENV=development
DEBUG=true
SQL_ECHO=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# База данных
DATABASE_URL=postgresql+asyncpg://ai_tutor:ai_tutor_pass@db/ai_tutor

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# AI провайдер — anthropic | yandex
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL_ANTHROPIC=claude-sonnet-4-5
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
AI_MODEL_YANDEX=yandexgpt-lite/latest

# Видеозвонки (Agora)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# SMTP для верификации email (Yandex Mail по умолчанию)
# Нужен app-password из Яндекс.Почты (ID → Безопасность → Пароли для приложений)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-account@yandex.ru
SMTP_PASSWORD=
SMTP_FROM_EMAIL=your-account@yandex.ru
SMTP_FROM_NAME=AI Tutor
EMAIL_VERIFY_TTL_HOURS=24
EMAIL_VERIFY_COOLDOWN_SECONDS=60
APP_DEEP_LINK_BASE=ai-tutor://verify
APP_PUBLIC_URL=http://localhost:8000
